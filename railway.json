{
  "$schema": "https://railway.app/railway.schema.json",
  "name": "SupoClip",
  "services": {
    "postgres": {
      "source": "image:postgres:15",
      "env": {
        "POSTGRES_DB": "supoclip",
        "POSTGRES_PASSWORD": "${{RAILWAY_DATABASE_PASSWORD}}",
        "POSTGRES_USER": "postgres"
      }
    },
    "redis": {
      "source": "image:redis:7"
    },
    "frontend": {
      "builder": "DOCKERFILE",
      "dockerfilePath": "./frontend/Dockerfile",
      "env": {
        "NEXT_PUBLIC_API_URL": "https://${{backend.RAILWAY_PUBLIC_DOMAIN}}",
        "NEXT_PUBLIC_APP_URL": "https://${{frontend.RAILWAY_PUBLIC_DOMAIN}}",
        "NEXT_PUBLIC_SELF_HOST": "true"
      }
    },
    "backend": {
      "builder": "DOCKERFILE",
      "dockerfilePath": "./backend/Dockerfile",
      "env": {
        "DATABASE_URL": "postgresql://postgres:${{postgres.POSTGRES_PASSWORD}}@${{postgres.RAILWAY_PRIVATE_DOMAIN}}:5432/supoclip",
        "REDIS_URL": "redis://${{redis.RAILWAY_PRIVATE_DOMAIN}}:6379",
        "BETTER_AUTH_URL": "https://${{frontend.RAILWAY_PUBLIC_DOMAIN}}",
        "SELF_HOST": "true"
      }
    },
    "worker": {
      "builder": "DOCKERFILE",
      "dockerfilePath": "./backend/Dockerfile",
      "startCommand": "python -m arq worker.WorkerSettings",
      "env": {
        "DATABASE_URL": "postgresql://postgres:${{postgres.POSTGRES_PASSWORD}}@${{postgres.RAILWAY_PRIVATE_DOMAIN}}:5432/supoclip",
        "REDIS_URL": "redis://${{redis.RAILWAY_PRIVATE_DOMAIN}}:6379"
      }
    }
  }
}
